# NextAuth v5
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# Email (dev mode uses console, set EMAIL_SERVER_* for production SMTP)
EMAIL_FROM=noreply@portfolio-social.com

# Admin - set this and run `npx tsx scripts/seed-admin.ts` to create admin
INITIAL_ADMIN_EMAIL=admin@example.com
